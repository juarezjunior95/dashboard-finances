# Variáveis de ambiente acessíveis no client-side devem começar com VITE_
# Docs: https://vite.dev/guide/env-and-mode

VITE_APP_TITLE=Dashboard de Finanças

# Supabase — obtenha em: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Groq AI — obtenha em: https://console.groq.com/keys (free tier)
VITE_GROQ_API_KEY=sua-groq-api-key-aqui
